{
    "manifest_version": 3,
    "name": "AI Chrome news buddy",
    "version": "1.0",
    
    "permissions": ["scripting", "storage", "activeTab"],

    "action":{
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],

    "background":{
        "service_worker": "background.js"
    },

    "options_page": "options.html",
    "host_permissions": ["<all_urls>"]
}